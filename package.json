{
  "name": "uni-monitor",
  "version": "0.1.0",
  "description": "Daily UNI (Uniswap) intelligence dashboard powered by Claude Opus 4.7",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "run:dry": "tsx src/index.ts --dry-run",
    "run:send": "tsx src/index.ts --send --save",
    "run:save": "tsx src/index.ts --save",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "node-telegram-bot-api": "^1.1.2",
    "nodemailer": "^9.0.3",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/node-telegram-bot-api": "^0.64.15",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
