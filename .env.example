# Anthropic API - required for AI daily synthesis
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Ethereum RPC - free public endpoints work, or use Alchemy/Infura for better reliability
# Recommended free option: https://ethereum-rpc.publicnode.com
ETH_RPC_URL=https://ethereum-rpc.publicnode.com

# Etherscan API - free tier (5 req/s)
# Get at https://etherscan.io/apis
ETHERSCAN_API_KEY=YourApiKeyToken

# --- Notification: choose one or more ---

# Email (SMTP)
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@email.com
SMTP_PASS=app-specific-password
EMAIL_TO=your@email.com

# Telegram Bot
NOTIFY_TG_ENABLED=false
TG_BOT_TOKEN=1234567890:AAxxxxxxxxxxxx
TG_CHAT_ID=123456789
